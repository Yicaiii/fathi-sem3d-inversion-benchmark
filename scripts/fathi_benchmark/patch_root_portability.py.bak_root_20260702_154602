from pathlib import Path
from datetime import datetime
import json
import re

PROJECT = Path.home() / "sem3d_fathi_clean"

TARGET_DIRS = [
    PROJECT / "scripts/fathi_benchmark",
    PROJECT / "scripts/iteration_engine",
    PROJECT / "scripts/armonik_demo",
    PROJECT / "scripts/armonik_worker",
]

EXTRA_FILES = [
    PROJECT / "scripts/longterm/424B_compute_rhs_component_from_traces.py",
]

OLD_LINES = [
    'ROOT = Path.home() / "sem3d_fathi_clean"',
    "ROOT = Path.home() / 'sem3d_fathi_clean'",
]

NEW_LINE = 'ROOT = Path(os.environ.get("FATHI_BENCHMARK_ROOT", str(Path.home() / "sem3d_fathi_clean"))).expanduser().resolve()'

def ensure_import_os(text):
    if re.search(r"^import os$", text, flags=re.M):
        return text

    # Prefer inserting after pathlib import, because ROOT line uses Path.
    m = re.search(r"^from pathlib import Path\s*$", text, flags=re.M)
    if m:
        insert_at = m.end()
        return text[:insert_at] + "\nimport os" + text[insert_at:]

    # Fallback: insert at top after shebang if present.
    lines = text.splitlines()
    if lines and lines[0].startswith("#!"):
        lines.insert(1, "import os")
    else:
        lines.insert(0, "import os")
    return "\n".join(lines) + ("\n" if text.endswith("\n") else "")

def patch_file(path):
    if not path.exists() or path.suffix != ".py":
        return None

    text = path.read_text(encoding="utf-8")
    original = text

    changed = False
    for old in OLD_LINES:
        if old in text:
            text = text.replace(old, NEW_LINE)
            changed = True

    if changed:
        text = ensure_import_os(text)
        backup = path.with_suffix(path.suffix + f".bak_root_{datetime.now().strftime('%Y%m%d_%H%M%S')}")
        backup.write_text(original, encoding="utf-8")
        path.write_text(text, encoding="utf-8")
        return {
            "path": str(path),
            "backup": str(backup),
            "patched": True,
        }

    return {
        "path": str(path),
        "patched": False,
    }

files = []
for d in TARGET_DIRS:
    if d.exists():
        files.extend(sorted(d.glob("*.py")))
files.extend(EXTRA_FILES)

records = []
for f in files:
    r = patch_file(f)
    if r is not None:
        records.append(r)

out_dir = PROJECT / "benchmark_fathi_strict/reports/root_portability"
out_dir.mkdir(parents=True, exist_ok=True)

payload = {
    "created": datetime.now().isoformat(),
    "records": records,
    "patched_count": sum(1 for r in records if r.get("patched")),
}

out_json = out_dir / "root_portability_patch.json"
out_txt = out_dir / "root_portability_patch.txt"

out_json.write_text(json.dumps(payload, indent=2), encoding="utf-8")

lines = []
lines.append("ROOT portability patch")
lines.append("======================")
lines.append("")
lines.append(f"patched_count = {payload['patched_count']}")
lines.append("")
for r in records:
    if r.get("patched"):
        lines.append(f"PATCHED {r['path']}")
        lines.append(f"  backup = {r['backup']}")
lines.append("")
lines.append(f"json = {out_json}")
lines.append("")
lines.append("RESULT = PASS")

out_txt.write_text("\n".join(lines), encoding="utf-8")
print("\n".join(lines))
